{
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json",
  "name": "hatchery",
  "compatibility_date": "2026-06-09",
  "compatibility_flags": ["nodejs_compat"],
  // Persisted logs (queryable in the dashboard) so a failed turn can be inspected after the fact
  // instead of racing a live `wrangler tail`. head_sampling_rate 1 = keep every invocation.
  "observability": { "enabled": true, "head_sampling_rate": 1 },
  "kv_namespaces": [
    { "binding": "SLACK_EVENTS", "id": "21c63a4fa37540159e6e8b0a1ac19b66" }
  ],
  // The cron clock, in-house since Flue 0.11 (the generated entry forwards `scheduled`,
  // so the external hatchery-ticker worker is retired). Expressions are mirrored as
  // constants in .flue/cloudflare.ts — keep both in sync. UTC, no DST shift.
  "triggers": {
    "crons": [
      "0 */6 * * *", // liveness backstop heartbeat
      "0 19 * * *", // nightly REM reflect-sweep (03:00 KL)
      "*/2 * * * *", // agent-run outbox reconcile
      "* * * * *" // reminder due-scan (minute precision)
    ]
  },
  // Coordinator Code Mode: project agents can run small JS/Python snippets in isolated
  // Dynamic Workers. The tool is still gated by DB so every execution has an audit row.
  "worker_loaders": [{ "binding": "DYNAMIC_WORKER_LOADER" }],
  // Project data store: skills, memory, transcripts, and conversation reply targets.
  // For skills, /__internal/scheduled loads bodies FRESH at fire time. Survives
  // Flue's wrangler merge.
  "d1_databases": [
    { "binding": "DB", "database_name": "hatchery-skills", "database_id": "6ac5de79-a8c0-4e08-aab8-b9b636278a9d" }
  ],
  // Flue 0.11 generates + merges the agent DO bindings itself (FLUE_PROJECT_AGENT,
  // FLUE_REGISTRY) — only application-owned DOs are declared here. The Sandbox class
  // is exported from .flue/cloudflare.ts (0.11 dropped the auto-wiring).
  "durable_objects": {
    "bindings": [
      // Workspace sandbox: real container with shell/fs/git for coordinator workspace tasks.
      { "name": "SANDBOX", "class_name": "Sandbox" }
    ]
  },
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile.sandbox",
      "instance_type": "lite",
      "max_instances": 1
    }
  ],
  "migrations": [
    { "tag": "flue-class-FlueRegistry", "new_sqlite_classes": ["FlueRegistry"] },
    { "tag": "flue-class-Project", "new_sqlite_classes": ["Project"] },
    { "tag": "sandbox-class", "new_sqlite_classes": ["Sandbox"] },
    // Flue 0.11: agent DOs are generated as Flue<Name>Agent. The old per-project
    // `Project` class is deleted (its session histories are rejected by 0.11 anyway;
    // the D1 `messages` transcript keeps the durable record — threads cold-start once).
    { "tag": "flue-011", "deleted_classes": ["Project"], "new_sqlite_classes": ["FlueProjectAgent"] }
  ]
}
