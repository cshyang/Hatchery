# ─────────────────────────────────────────────────────────────────────────────
# .env.deploy — the ONE file you fill to stand up Hatchery on a new Cloudflare
# account. Copy to `.env.deploy` (gitignored) and fill in. Then run ./scripts/setup.sh.
#
# Everything here is pushed as a Worker secret/var by setup.sh — nothing account-
# specific stays in source. Leave optional values blank to skip that feature
# (its routes deploy inert until the secret exists).
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED: core ───────────────────────────────────────────────────────────
# Model backend (Z.ai GLM coding plan). Without it the agent cannot take a turn.
ZAI_API_KEY=

# Shared heartbeat secret. setup.sh GENERATES one if left blank and sets it on
# BOTH workers (hatchery + hatchery-ticker) so the cron clock can poke the app.
HEARTBEAT_TOKEN=

# ── REQUIRED: Slack ingress ──────────────────────────────────────────────────
# From your Slack app (create it from slack-app.manifest.json — see README step 4).
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN_DEFAULT=          # xoxb-… bot token

# Account-coupled identity (replaces the old hardcoded literals in src/config/deployment.ts).
KNOWN_TEAM_IDS=                   # your Slack team id(s), comma-separated, e.g. T0ABC123
SLACK_BOT_ID=                     # your bot user id, e.g. U0ABC123 (for @mention + autocreate)
# SLACK_DEFAULT_TOKEN_REF=SLACK_BOT_TOKEN_DEFAULT   # only change if you rename the token secret

# ── REQUIRED: admin guard ────────────────────────────────────────────────────
# Guards /__admin/* (connection + agent-run-route activation). Generate a random string.
ADMIN_CONNECTIONS_TOKEN=

# ── Connections via Nango (self-serve OAuth). Blank → /nango/webhook is inert. ─
NANGO_SECRET_KEY=
NANGO_WEBHOOK_SECRET=

# ── Linear agent-run control plane. Blank → /linear/webhook is inert. ─────────
LINEAR_WEBHOOK_SECRET=
TRIGGER_SECRET_KEY=               # Trigger.dev secret key; Hatchery dispatches run-coding-task through it
# TRIGGER_API_URL=https://api.trigger.dev
AGENT_RUNNER_TOKEN=               # shared secret for runner callbacks
HATCHERY_PUBLIC_URL=              # absolute Worker origin used in runner callbacks
RUNNER_GITHUB_PAT_TEMP=           # temporary dogfood PAT; replace with GitHub App tokens later
# LINEAR_AGENT_PROJECTS={}        # optional legacy fallback; prefer admin-activated agent_run_routes

# ── Workbench source-change runner (optional) ────────────────────────────────
# WORKBENCH_RUNNER_TOKEN=
# CODING_RUNNER_URL=
