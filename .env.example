# Local dev: copy to `.dev.vars` (read by `flue dev --target cloudflare`). Never commit secrets.
# Production: set as Worker secrets, e.g. `npx wrangler secret put ZAI_API_KEY`.

# Model backend: Z.ai GLM Coding Plan.
# pi-ai's native `zai` provider already targets Z.ai's coding endpoint
# (https://api.z.ai/api/coding/paas/v4), and the agent uses model `zai/glm-4.6`,
# so this key is all that's needed.
ZAI_API_KEY="your-zai-coding-plan-key"

# Alternative — Anthropic-compatible endpoint (if your plan key is scoped to it):
# add to .flue/app.ts (module scope):
#   import { configureProvider } from '@flue/runtime/app';
#   import { env } from 'cloudflare:workers';   // may need @cloudflare/workers-types
#   configureProvider('anthropic', {
#     baseUrl: 'https://api.z.ai/api/anthropic',
#     apiKey: (env as { ZAI_API_KEY?: string }).ZAI_API_KEY ?? '',
#   });
# and set the agent model to 'anthropic/glm-4.6'.

# Slack (Step B) — app signing secret + a bot token per project binding.
# SLACK_SIGNING_SECRET="..."
# SLACK_BOT_TOKEN_DEFAULT="xoxb-..."
